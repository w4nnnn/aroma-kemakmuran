# ==========================================
# KONFIGURASI APLIKASI (NEXT.JS & POCKETBASE)
# ==========================================

# MODE LINGKUNGAN (development / production)
# development: Hot-reload aktif, error stack tampil
# production: Optimasi cache aktif, log minimal, keamanan ketat
NODE_ENV=development

# URL publik untuk Browser / Client Components Next.js
# - Local/Development: Biasanya http://localhost:2200
# - Production: Ganti dengan domain asli Anda (contoh: https://aromakemakmuran.com)
NEXT_PUBLIC_PB_URL=http://localhost:2200

# URL internal PocketBase (Digunakan oleh Docker / Next.js Server proxy)
# Jangan diubah jika menggunakan docker-compose bawaan
INTERNAL_PB_URL=http://pocketbase:8090
