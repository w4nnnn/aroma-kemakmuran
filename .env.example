# ==========================================
# KONFIGURASI DOCKER PORTS (HOST)
# ==========================================
# Port yang akan digunakan untuk mengakses Frontend di browser Anda
FRONTEND_PORT=2200

# [DEVELOPMENT ONLY]
# Port yang akan digunakan untuk mengakses PocketBase Backend (Dashboard) secara langsung.
# Di Production, biarkan kosong atau beri komentar (comment) pada PB_PORT di .env
# karena PocketBase akan berjalan tertutup di belakang proxy Next.js
PB_PORT=8090

# ==========================================
# KONFIGURASI APLIKASI (NEXT.JS & POCKETBASE)
# ==========================================

# MODE LINGKUNGAN (development / production)
# development: Hot-reload aktif, error stack tampil, port PB terbuka jika diset
# production: Optimasi cache aktif, log minimal, keamanan ketat
NODE_ENV=development

# URL publik PocketBase (Digunakan oleh Browser / Client Components Next.js)
# PENTING: Sejak menggunakan arsitektur Proxy (Server-Side Auth), set URL ini 
# ke domain Next.js Anda jika di production. Jika lokal, biarkan seperti di bawah.
NEXT_PUBLIC_PB_URL=http://localhost:2200

# URL internal PocketBase (Digunakan oleh Docker / Next.js Server proxy)
# Jangan diubah jika menggunakan docker-compose bawaan
INTERNAL_PB_URL=http://pocketbase:8090
