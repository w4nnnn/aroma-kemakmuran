# ==========================================
# KONFIGURASI APLIKASI (NEXT.JS & SUPABASE + DRIZZLE)
# ==========================================

# MODE LINGKUNGAN (development / production)
NODE_ENV=development

# Supabase (Auth & Storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Database (Drizzle ORM - direct PostgreSQL connection)
# Dapatkan dari Supabase Dashboard > Project Settings > Database > Connection String
DATABASE_URL=postgresql://postgres.your-ref:password@host:6543/postgres
